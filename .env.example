# ══════════════════════════════════════════════════════════════════════════════
# DEBUG / DEV
# ══════════════════════════════════════════════════════════════════════════════
# DEBUG_TRAFFIC_LOG=false
# PROXY_CHAIN_FILE=./config/proxy_chain.json
# CB_STATE_FILE=data/circuit_breaker_state.json
# CB_FAILURE_THRESHOLD=3       # Failures before circuit opens (default: 3)
# CB_SUCCESS_THRESHOLD=1       # Successes in half-open before closing (default: 1)
# CB_TIMEOUT_SECONDS=300       # Cooldown seconds before half-open probe (default: 300 = 5 min)
# DATA_DIR=data
# LOG_FILE=
# LOG_STYLE=
# USE_LOCAL_PROXY=false
# EXA_API_KEY=
# AA_API_KEY=           # Artificial Analysis API key — used by model_ranker.py and model-scan
#                       # to enrich model scores with intelligence benchmarks (MMLU, HumanEval, etc.)
#                       # Get key at: https://artificialanalysis.ai