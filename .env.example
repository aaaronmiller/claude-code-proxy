# ══════════════════════════════════════════════════════════════════════════════
# MODEL ROUTER (per use-case routing)
# ══════════════════════════════════════════════════════════════════════════════
# ROUTER_DEFAULT=
# ROUTER_BACKGROUND=nvidia/nemotron-nano-9b-v2:free
# ROUTER_THINK=
# ROUTER_LONG_CONTEXT=minimax/minimax-m2.5:free
# ROUTER_LONG_CONTEXT_THRESHOLD=60000
# ROUTER_WEB_SEARCH=
# ROUTER_IMAGE=qwen/qwen2.5-vl-72b-instruct
# ROUTER_CUSTOM_PATH=

# ══════════════════════════════════════════════════════════════════════════════
# ASSIGNMENT-BASED CONFIGURATION — preferred (FR-003)
# ══════════════════════════════════════════════════════════════════════════════
# Unified schema: assignments.<id>.<field>
#  id   = tier name (big, middle, small) OR custom slot name
#  field = model, provider, base_url, api_key, enabled, cascade
# Uses UPPER_SNAKE_CASE env var names with underscores instead of dots.
# Example for a custom slot:
# ASSIGNMENTS_document_summarizer_model=anthropic/claude-haiku-4.5
# ASSIGNMENTS_document_summarizer_provider=anthropic
# ASSIGNMENTS_document_summarizer_api_key=${ANTHROPIC_API_KEY}
# ASSIGNMENTS_document_summarizer_enabled=true
# ASSIGNMENTS_document_summarizer_cascade=openai/gpt-4o-mini,openrouter/nvidia/nemotron-70b:free
#
# The legacy BIG_/MIDDLE_/SMALL_ variables (below) map to assignments.big/middle/small
# during the deprecation window. Prefer assignments_* for all new configs.
#
# See docs/configuration.md for full precedence and migration guide.

# ══════════════════════════════════════════════════════════════════════════════
# FALLBACK / CASCADE
# ══════════════════════════════════════════════════════════════════════════════
# FALLBACK_METHOD=cascade,openrouter_native
# MODEL_CASCADE=true
# OPENROUTER_FALLBACK_MODELS=qwen/qwen3-235b-a22b:free,minimax/minimax-m2.5:free
# MODEL_CASCADE_DAILY_LIMIT=1000

# Token budget enforcement (0 = disabled)
# DAILY_TOKEN_BUDGET=500000        # Total tokens allowed per UTC day across all requests
# PER_REQUEST_TOKEN_BUDGET=50000   # Max input tokens per single request (rejects oversized prompts)
# DAILY_COST_BUDGET=1.00           # Max USD spend per UTC day (rejects requests when budget exhausted)
# HEADROOM_BYPASS_THRESHOLD=500    # Skip headroom compression for requests below this token count (0=disabled)
# MID_STREAM_OUTPUT_BUDGET=2000    # Stop expensive model after N output tokens, route next turn to cheaper tier (0=disabled)

# Local GPU inference (4th cascade tier — ollama / llamafile)
# LOCAL_ENABLED=true               # Enable local inference fallback
# LOCAL_MODEL=llama3.2             # Model name as ollama knows it (e.g. llama3.2, mistral, phi3)
# LOCAL_ENDPOINT=http://localhost:11434/v1   # ollama default; use http://localhost:8080/v1 for llamafile

# Watchdog (set in shell, not .env — it controls proxies tmux session startup)
# PROXY_WATCHDOG=true              # Start auto-recovery watchdog pane (checks health every 30s, restarts dead services)
# WATCHDOG_INTERVAL=30             # Health check interval in seconds
# WATCHDOG_GRACE=5                 # Seconds to wait before restarting after first failure

# ══════════════════════════════════════════════════════════════════════════════
# TOOL-CALLING FALLBACK
# ══════════════════════════════════════════════════════════════════════════════
# When a request contains tools[] and the primary model doesn't support tool
# calling, the proxy auto-routes to these models (tried in order).
# Requires MODEL_CASCADE=true.
#
# TOOLCALL_MODELS=tencent/hy3-preview:free,nvidia/nemotron-3-super-120b-a12b:free,minimax/minimax-m2.5:free,openai/gpt-oss-120b:free
# TOOLCALL_AUTO_ROUTE=true
# TOOLCALL_MAX_RETRIES=2
#
# Provider-specific tool-calling overrides (optional):
# TOOLCALL_openrouter=tencent/hy3-preview:free

# ══════════════════════════════════════════════════════════════════════════════
# REASONING
# ══════════════════════════════════════════════════════════════════════════════
# REASONING_EFFORT=low
# REASONING_MAX_TOKENS=32000
# REASONING_EXCLUDE=false

# ══════════════════════════════════════════════════════════════════════════════
# OUTPUT & LOGGING
# ══════════════════════════════════════════════════════════════════════════════
# TOOL_OUTPUT_MAX_CHARS=50000
# MIN_TOKENS_LIMIT=100
# MAX_TOKENS_LIMIT=32000
# TOOL_OUTPUT_TRUNCATION=true
# LOG_TIER=production
# LOGS_DIR=logs
# LOG_MAX_SIZE_MB=50
# LOG_RETENTION_DAYS=7
# LOG_LEVEL=info

# ══════════════════════════════════════════════════════════════════════════════
# DISPLAY & TERMINAL
# ══════════════════════════════════════════════════════════════════════════════
# ENABLE_DASHBOARD=false
# DASHBOARD_LAYOUT=default
# DASHBOARD_REFRESH=0.5
# DASHBOARD_WATERFALL_SIZE=20
# TERMINAL_SHOW_WORKSPACE=true
# TERMINAL_SHOW_CONTEXT_PCT=true
# TERMINAL_SHOW_TASK_TYPE=true
# TERMINAL_SHOW_SPEED=true
# TERMINAL_SHOW_COST=true
# TERMINAL_SHOW_DURATION_COLORS=true
# TERMINAL_COLOR_SCHEME=auto
# TERMINAL_SESSION_COLORS=true

# ══════════════════════════════════════════════════════════════════════════════
# CONNECTION
