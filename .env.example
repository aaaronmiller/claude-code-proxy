# ══════════════════════════════════════════════════════════════════════════════
# Claude Code Proxy — Configuration Reference
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
#
# FOUR WAYS TO CONFIGURE:
#   1. .env file (this file)            → persists across restarts
#   2. Shell env / direnv               → overrides .env
#   3. CLI flags (python start_proxy.py --host 0.0.0.0)
#   4. TUI  (python start_proxy.py --configure-advanced)
#   5. Web UI  http://localhost:8082/settings
#
# All 62 settings are documented here. Uncomment and set what you need.
# ══════════════════════════════════════════════════════════════════════════════


# ── SERVER ────────────────────────────────────────────────────────────────────
# Server bind address
HOST=0.0.0.0
# Server port
PORT=8082
# Logging verbosity: debug | info | warning | error
LOG_LEVEL=info
# Upstream request timeout (seconds)
# REQUEST_TIMEOUT=120
# Max upstream retries before cascade
# MAX_RETRIES=2


# ── MODELS ────────────────────────────────────────────────────────────────────
# BIG tier model (opus-level) — e.g. anthropic/claude-opus-4-20250514
BIG_MODEL=
# MIDDLE tier model (sonnet-level) — e.g. openrouter/claude-sonnet-4-5
MIDDLE_MODEL=
# SMALL tier model (haiku-level) — e.g. openrouter/claude-haiku-4-5
SMALL_MODEL=
# BIG tier fallback models (comma-separated, tried in order on failure)
# BIG_CASCADE=minimax/minimax-m2.5:free,qwen/qwen3-235b-a22b:free
# MIDDLE_CASCADE=minimax/minimax-m2.5:free
# SMALL_CASCADE=openai/gpt-4o-mini
# Enable cascade fallback on model failures
MODEL_CASCADE=true
# Max cascade requests per model per day (0=unlimited)
# MODEL_CASCADE_DAILY_LIMIT=0
# Dynamic OpenRouter fallback pool (comma-separated)
# OPENROUTER_FALLBACK_MODELS=


# ── REASONING & THINKING ──────────────────────────────────────────────────────
# Default reasoning effort: low | medium | high
# REASONING_EFFORT=low
# Max thinking tokens for extended reasoning
# REASONING_MAX_TOKENS=32000
# Strip thinking tokens from response (reduce output size)
# REASONING_EXCLUDE=false
# Per-tier reasoning override for BIG model (overrides REASONING_EFFORT for that tier)
# BIG_MODEL_REASONING=high
# Per-tier reasoning override for MIDDLE model
# MIDDLE_MODEL_REASONING=low


# ── ROUTER SLOTS ─────────────────────────────────────────────────────────────
# Assign specific models to use-case tags. Empty = use tier default.
# Model for background/async tasks
# ROUTER_BACKGROUND=nvidia/nemotron-nano-9b-v2:free
# Model for reasoning/thinking requests
# ROUTER_THINK=nvidia/nemotron-3-super-120b-a12b:free
# Model for long-context requests
# ROUTER_LONG_CONTEXT=
# Token threshold for long-context routing (tokens)
# ROUTER_LONG_CONTEXT_THRESHOLD=60000
# Model for web search tool requests
# ROUTER_WEB_SEARCH=nvidia/nemotron-nano-9b-v2:free
# Model for image/vision requests
# ROUTER_IMAGE=qwen/qwen2.5-vl-72b-instruct:free


# ── BUDGET & COST CONTROLS ────────────────────────────────────────────────────
# Max tokens per UTC day across all requests (0=disabled)
# DAILY_TOKEN_BUDGET=0
# Max input tokens per single request (0=disabled)
# PER_REQUEST_TOKEN_BUDGET=0
# Max USD spend per UTC day (0=disabled)
# DAILY_COST_BUDGET=0.0
# Stop expensive model after N output tokens, route next turn cheaper (0=disabled)
# MID_STREAM_OUTPUT_BUDGET=0


# ── CIRCUIT BREAKER ───────────────────────────────────────────────────────────
# Failures before circuit opens (trips model as dead)
# CB_FAILURE_THRESHOLD=3
# Successes in half-open state before circuit closes
# CB_SUCCESS_THRESHOLD=1
# Cooldown seconds before half-open probe (default: 5 min)
# CB_TIMEOUT_SECONDS=300


# ── COMPRESSION ───────────────────────────────────────────────────────────────
# Skip headroom compression for requests below this token count (0=disabled)
# HEADROOM_BYPASS_THRESHOLD=0
# Headroom accelerator: auto, intel, nvidia, cpu
# HEADROOM_ACCELERATOR=auto
# Intel/OpenVINO Kompress device. On Arc A370M WSL this is GPU.0.
# HEADROOM_KOMPRESS_DEVICE=GPU.0
# Relay local :8787 to a shared LAN Headroom host instead of starting local Headroom
# HEADROOM_REMOTE_URL=http://gpu-box.local:8787
# Upstream gateway URL used by local Headroom
# HEADROOM_UPSTREAM_URL=http://127.0.0.1:8082
# Allow CPU retry if GPU preload fails
# HEADROOM_ALLOW_CPU_FALLBACK=1
# Strip redundant fields from tool schemas to reduce token burn
TOOL_SCHEMA_STRIP=true
# Max characters for tool-level description
# TOOL_DESC_MAX=200
# Max characters for per-property description
# TOOL_PARAM_DESC_MAX=120
# Enable semantic dedup cache (skips provider call for near-duplicate prompts)
SEMANTIC_CACHE_ENABLED=true
# Similarity threshold for semantic cache hits (0.0-1.0)
# SEMANTIC_CACHE_THRESHOLD=0.97
# Max entries in semantic cache (LRU)
# SEMANTIC_CACHE_SIZE=256
# Seconds before semantic cache entry expires
# SEMANTIC_CACHE_TTL=3600
# LRU cache slots for tiktoken encoding results
# TOKEN_COUNT_CACHE_SIZE=512


# ── LOCAL GPU (4th cascade tier) ─────────────────────────────────────────────
# Enable local GPU inference (ollama/llamafile) as 4th cascade tier
# LOCAL_ENABLED=false
# Local model name (e.g. llama3.2, mistral, phi3)
# LOCAL_MODEL=llama3.2
# Local inference endpoint (ollama default: :11434/v1)
# LOCAL_ENDPOINT=http://localhost:11434/v1


# ── TOOL CALLS ────────────────────────────────────────────────────────────────
# Tool-call capable models prepended to cascade (comma-separated)
# TOOLCALL_MODELS=
# Auto-detect tool-call requests and use TOOLCALL_MODELS
# TOOLCALL_AUTO_ROUTE=true
# Max retries per model in tool-call cascade
# TOOLCALL_MAX_RETRIES=2
# Max characters per tool output (truncation)
# TOOL_OUTPUT_MAX_CHARS=50000
# Enable tool output truncation (for small-context models)
# TOOL_OUTPUT_TRUNCATION=false


# ── AUTH & API KEYS ───────────────────────────────────────────────────────────
# Client access key (clients must present this to use the proxy; empty=no auth)
# PROXY_AUTH_KEY=
# OpenRouter API key
OPENROUTER_API_KEY=${OPENROUTER_API_KEY}
# Artificial Analysis API key (for intelligence benchmark scores)
# AA_API_KEY=


# ── LOGGING ───────────────────────────────────────────────────────────────────
# Proxy log file path
# LOG_FILE=logs/proxy.log
# Max log file size before rotation (MB)
# LOG_MAX_SIZE_MB=50
# Days to keep rotated logs
# LOG_RETENTION_DAYS=7
# Dump full HTTP request/response headers to logs/ (verbose)
# DEBUG_TRAFFIC_LOG=false


# ── WATCHDOG ─────────────────────────────────────────────────────────────────
# Start auto-recovery watchdog pane (checks health, restarts dead services)
# PROXY_WATCHDOG=false
# Watchdog health check frequency (seconds)
# WATCHDOG_INTERVAL=30
# Seconds to wait before restarting after first failure
# WATCHDOG_GRACE=5


# ── USAGE TRACKING ────────────────────────────────────────────────────────────
# Record request statistics to SQLite database
TRACK_USAGE=true
# SQLite database file path for usage tracking
# USAGE_TRACKING_DB_PATH=usage_tracking.db
# Suppress deprecated env-var warnings on startup
# SILENCE_DEPRECATION_WARNINGS=false


# ── PROVIDER ASSIGNMENTS (recommended over legacy BIG_MODEL etc.) ─────────────
# Modern assignment system — set per-tier endpoints and API keys
# See: python start_proxy.py --list-assignments
#
# PROVIDERS_anthropic_API_KEY=${ANTHROPIC_API_KEY}
# PROVIDERS_openai_API_KEY=${OPENAI_API_KEY}
