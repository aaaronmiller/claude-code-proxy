#!/usr/bin/env bash
# ═══════════════════════════════════════════════════════════════════════════════
# xx — unified LLM launcher.  Grammar:  xx <agent><run>[route][model] [opts] [prompt]
#
# CANONICAL SOURCE: claude-code-proxy/scripts/xx
#   ~/.local/bin/xx is a SYMLINK to this file, so edits here are live immediately.
#
# CODE = <agent><run>[route][model]   (route defaults to proxy; model only with proxy)
#   agent : c claude  h hermes  x codex  o opencode  q qwen  p pi  a ante  g antigravity
#   run   : i init  c continue  r resume      (lowercase = interactive)
#           I init  C continue  R resume      (UPPERCASE = headless, needs a prompt)
#   route : p proxy(default,+Headroom/RTK+reroute)  b bypass(native model)  d direct(raw)
#   model : m best  f free  t tool  r reason  v verify  s fast  0-9 profile  (proxy only)
# Model/route/selector tables live in ~/.xx/config.json.
# ═══════════════════════════════════════════════════════════════════════════════
set -euo pipefail

XX_CONFIG="${XX_CONFIG:-$HOME/.xx/config.json}"
PROXY_BASE="http://127.0.0.1:8082"
PROXY_HEALTH="http://127.0.0.1:8082/health"
HEADROOM_HEALTH="http://127.0.0.1:8787/health"
AUTO_START=1

RED=$'\033[0;31m'; CYAN=$'\033[0;36m'; YEL=$'\033[0;33m'; GRN=$'\033[0;32m'; DIM=$'\033[2m'; NC=$'\033[0m'
die()  { echo -e "${RED}xx:${NC} $*" >&2; exit 1; }
note() { echo -e "${CYAN}xx:${NC} $*" >&2; }
warn() { echo -e "${YEL}xx:${NC} $*" >&2; }

# ── Single-screen, multi-column help ─────────────────────────────────────────
usage() {
cat <<H
${CYAN}xx${NC} — LLM launcher   ${DIM}xx <code> [opts] [prompt]  ·  xx <command>${NC}
${DIM}code = <agent><run>[route][model]   route defaults to proxy${NC}

${GRN}AGENT${NC}          ${GRN}RUN${NC} ${DIM}(lower=interactive UPPER=headless)${NC}   ${GRN}ROUTE${NC}        ${GRN}MODEL${NC} ${DIM}(proxy only)${NC}
 c claude        i/I init       r/R resume          p proxy*      m best    r reason
 h hermes        c/C continue                       b bypass      f free    v verify
 x codex         ${DIM}o${NC} opencode  ${DIM}q${NC} qwen              d direct      t tool    s fast
 p pi   a ante   g antigravity                                    0-9 profile slot

${GRN}OPTS${NC}  -s session  -P provider  -m model  -p prompt  --stdin  -n dry-run  -v  --no-cg  -h
${GRN}CMDS${NC}  doctor  models  sessions
${GRN}RULES${NC} route=proxy default · model needs proxy(not b/d) · headless(UPPER) needs a prompt
${GRN}EX${NC}  xx ci · xx cc · xx cI "task" · xx cIf -P openrouter "task" · xx cib · xx cCd "task"
H
exit "${1:-0}"
}

# ── config reader (no jq dep) ────────────────────────────────────────────────
_cfg() {
    [ -f "$XX_CONFIG" ] || return 0
    python3 - "$XX_CONFIG" "$1" <<'PYEOF' 2>/dev/null || true
import json, sys
try: d = json.load(open(sys.argv[1]))
except Exception: sys.exit(0)
try: v = eval(sys.argv[2], {"d": d})
except Exception: v = None
if v is not None: print(v)
PYEOF
}
_healthy() { curl -sf --max-time 1 "$1" >/dev/null 2>&1; }

# Load proxy settings from config (env/defaults otherwise)
_v=$(_cfg "d['proxy']['base_url']");            [ -n "$_v" ] && PROXY_BASE="$_v"
_v=$(_cfg "d['proxy']['health_url']");          [ -n "$_v" ] && PROXY_HEALTH="$_v"
_v=$(_cfg "d['proxy']['headroom_health_url']"); [ -n "$_v" ] && HEADROOM_HEALTH="$_v"
_v=$(_cfg "d['proxy']['auto_start']");          [ "$_v" = "False" ] && AUTO_START=0

# ── model-scan resolver (config selectors first, then live proxy, else warn) ──
_scan() { # <kind> <provider>
    local kind="$1" prov="${2:-}" m
    m="$(_cfg "d['selectors'].get('$kind')")"
    [ -n "$m" ] && { echo "$m"; return; }
    if _healthy "$PROXY_HEALTH"; then
        m="$(curl -sf --max-time 3 "$PROXY_BASE/model-scan/pick?kind=$kind${prov:+&provider=$prov}" 2>/dev/null \
            | python3 -c 'import sys,json;print(json.load(sys.stdin).get("model",""))' 2>/dev/null || true)"
    fi
    echo "$m"
}
resolve_model() { # <code> <provider>
    local code="$1" prov="${2:-}" m=""
    case "$code" in
        [0-9]) m="$(_cfg "d['profiles'].get('$code')")" ;;
        m) m="$(_scan best "$prov")" ;;     f) m="$(_scan free "$prov")" ;;
        t) m="$(_scan tool "$prov")" ;;     r) m="$(_scan reasoning "$prov")" ;;
        v) m="$(_scan verifier "$prov")" ;; s) m="$(_scan fast "$prov")" ;;
    esac
    [ -n "$m" ] || warn "model selector '$code' unresolved — using config/proxy default"
    echo "$m"
}

# ── subcommands ──────────────────────────────────────────────────────────────
cmd_doctor() {
    echo -e "${CYAN}xx doctor${NC}"
    _healthy "$PROXY_HEALTH"    && echo -e "  proxy 8082    ${GRN}UP${NC}"   || echo -e "  proxy 8082    ${RED}DOWN${NC} ${DIM}(proxies up)${NC}"
    _healthy "$HEADROOM_HEALTH" && echo -e "  headroom 8787 ${GRN}UP${NC}"   || echo -e "  headroom 8787 ${RED}DOWN${NC}"
    command -v rtk    >/dev/null 2>&1 && echo -e "  rtk           ${GRN}ok${NC}" || echo -e "  rtk           ${YEL}missing${NC}"
    command -v cg_run >/dev/null 2>&1 && echo -e "  crash-guard   ${GRN}ok${NC}" || echo -e "  crash-guard   ${DIM}absent${NC}"
    [ -f "$XX_CONFIG" ] && echo -e "  config        ${GRN}$XX_CONFIG${NC}" || echo -e "  config        ${YEL}none${NC} ${DIM}($XX_CONFIG)${NC}"
}
cmd_models() {
    if _healthy "$PROXY_HEALTH"; then
        curl -sf --max-time 5 "$PROXY_BASE/model-scan/dashboard?limit=30" 2>/dev/null || echo "model-scan endpoint unavailable"
    else
        echo "proxy down — start it:  proxies up"
        _cfg "d.get('selectors')"; _cfg "d.get('profiles')"
    fi
}
cmd_sessions() {
    echo -e "${CYAN}Claude${NC} (recent):"
    find "$HOME/.claude/projects" -name '*.jsonl' -printf '%T@ %p\n' 2>/dev/null \
        | sort -rn | head -8 | awk '{cmd="date -d @"int($1)" +%m-%d_%H:%M"; cmd|getline t; close(cmd); print "  "t"  "$2}'
    for d in "$HOME"/.pi/sessions "$HOME"/.hermes/sessions; do
        [ -d "$d" ] && { echo -e "${CYAN}${d##*/.}${NC}:"; ls -t "$d" 2>/dev/null | head -5 | sed 's/^/  /'; }
    done
}

# ── dispatch ─────────────────────────────────────────────────────────────────
[ $# -ge 1 ] || usage 0
case "$1" in
    -h|--help|help) usage 0 ;;
    doctor)   cmd_doctor;   exit 0 ;;
    models)   cmd_models;   exit 0 ;;
    sessions) cmd_sessions; exit 0 ;;
esac

CODE="$1"; shift
[ ${#CODE} -ge 2 ] || die "code '$CODE' too short — need <agent><run> e.g. 'ci' (see -h)"
[ ${#CODE} -le 4 ] || die "code '$CODE' too long — max <agent><run><route><model> e.g. 'cIpf'"
AGENT="${CODE:0:1}"; RUN="${CODE:1:1}"; REST="${CODE:2}"

# ── parse route + model out of REST (0-2 chars) ──────────────────────────────
ROUTE="p"; MODELCODE=""
case "${#REST}" in
    0) ;;
    1) case "$REST" in
           p|b|d)             ROUTE="$REST" ;;
           m|f|t|r|v|s|[0-9]) MODELCODE="$REST" ;;
           *) die "bad route/model char '$REST' in '$CODE' (route p/b/d · model m f t r v s 0-9)" ;;
       esac ;;
    2) ROUTE="${REST:0:1}"; MODELCODE="${REST:1:1}"
       case "$ROUTE"     in p|b|d) ;;              *) die "bad route '$ROUTE' (p/b/d)" ;; esac
       case "$MODELCODE" in m|f|t|r|v|s|[0-9]) ;;  *) die "bad model '$MODELCODE' (m f t r v s 0-9)" ;; esac ;;
esac
# RULE: model selectors only apply on proxy route
if [ -n "$MODELCODE" ] && [ "$ROUTE" != "p" ]; then
    die "model selector '$MODELCODE' is invalid with route '$ROUTE' — reroute only happens on proxy (p)"
fi

# ── decode run → base + headless ─────────────────────────────────────────────
case "$RUN" in
    i) RUNBASE=init;     HEADLESS=0 ;;  I) RUNBASE=init;     HEADLESS=1 ;;
    c) RUNBASE=continue; HEADLESS=0 ;;  C) RUNBASE=continue; HEADLESS=1 ;;
    r) RUNBASE=resume;   HEADLESS=0 ;;  R) RUNBASE=resume;   HEADLESS=1 ;;
    *) die "bad run '$RUN' — i/c/r interactive, I/C/R headless" ;;
esac

# ── options + trailing prompt ────────────────────────────────────────────────
SESSION=""; PROVIDER=""; MODEL=""; PROMPT=""; USE_STDIN=0; DRYRUN=0; VERBOSE=0; CRASH_GUARD=1; POS=()
while [ $# -gt 0 ]; do
    case "$1" in
        -s|--session)  SESSION="${2:-}";  shift 2 ;;
        -P|--provider) PROVIDER="${2:-}"; shift 2 ;;
        -m|--model)    MODEL="${2:-}";    shift 2 ;;
        -p|--prompt)   PROMPT="${2:-}";   shift 2 ;;
        --stdin)       USE_STDIN=1;       shift ;;
        -n|--dry-run)  DRYRUN=1;          shift ;;
        -v|--verbose)  VERBOSE=1;         shift ;;
        --no-cg)       CRASH_GUARD=0;     shift ;;
        -h|--help)     usage 0 ;;
        --)            shift; while [ $# -gt 0 ]; do POS+=("$1"); shift; done ;;
        *)             POS+=("$1");       shift ;;
    esac
done
[ "$USE_STDIN" = 1 ] && PROMPT="$(cat)"
[ -z "$PROMPT" ] && [ ${#POS[@]} -gt 0 ] && PROMPT="${POS[*]}"
# RULE: headless needs a prompt
if [ "$HEADLESS" = 1 ] && [ -z "$PROMPT" ]; then
    die "headless run ('$RUN') needs a prompt — add trailing text, -p <text>, or --stdin"
fi

# ── agent → tool/profile/proto ───────────────────────────────────────────────
case "$AGENT" in
    c) AGENT_NAME=claude;     PROFILE=claude;     PROTO=anthropic ;;
    h) AGENT_NAME=hermes;     PROFILE=hermes;     PROTO=openai ;;
    x) AGENT_NAME=codex;      PROFILE=codex;      PROTO=openai ;;
    q) AGENT_NAME=qwen;       PROFILE=default;    PROTO=openai ;;
    p) AGENT_NAME=pi;         PROFILE=pi;         PROTO=openai ;;
    o) AGENT_NAME=opencode;   PROFILE=opencode;   PROTO=openai ;;
    a) AGENT_NAME=ante;       PROFILE=ante;       PROTO=openai ;;
    g) AGENT_NAME=antigravity;PROFILE=antigravity;PROTO=openai ;;
    *) die "unknown agent '$AGENT' (c h x o q p a g)" ;;
esac

# bypass → native profile (no reroute)
if [ "$ROUTE" = "b" ]; then
    case "$AGENT" in h) PROFILE=hermes-bypass ;; p) PROFILE=pi-bypass ;; esac
fi
# resolve model (proxy only; -m wins)
if [ "$ROUTE" = "p" ] && [ -z "$MODEL" ] && [ -n "$MODELCODE" ]; then
    MODEL="$(resolve_model "$MODELCODE" "$PROVIDER")"
fi

# ── proxy health + auto-start (headless; never spawns a GUI window) ───────────
if [ "$ROUTE" != "d" ] && [ "$AUTO_START" = 1 ] && [ "$DRYRUN" = 0 ]; then
    if ! _healthy "$PROXY_HEALTH" || ! _healthy "$HEADROOM_HEALTH"; then
        note "proxy chain down — starting headless in background…"
        mkdir -p "$HOME/.xx"
        PROXIES_NO_ATTACH=1 proxies up >>"$HOME/.xx/proxies.log" 2>&1 &
        note "waiting for proxies… (log: ~/.xx/proxies.log)"
        _w=0; while [ $_w -lt 60 ]; do
            _healthy "$PROXY_HEALTH" && _healthy "$HEADROOM_HEALTH" && { note "proxies ready"; break; }
            sleep 2; _w=$((_w+2))
        done
        _healthy "$PROXY_HEALTH" && _healthy "$HEADROOM_HEALTH" || warn "proxies not healthy after 60s — continuing"
    fi
fi

# ── routing env ──────────────────────────────────────────────────────────────
declare -a ENVV=()
if [ "$ROUTE" = "d" ]; then
    [ "$VERBOSE" = 1 ] && note "direct route: raw CLI, no proxy/Headroom/RTK"
elif [ "$PROTO" = "anthropic" ]; then
    ENVV+=("ANTHROPIC_BASE_URL=$PROXY_BASE/p/$PROFILE" "ANTHROPIC_API_KEY=pass")
else
    ENVV+=("OPENAI_BASE_URL=$PROXY_BASE/p/$PROFILE/v1" "OPENAI_API_KEY=pass")
fi

# ── build command (per-tool, normalized init/continue/resume × interactive/headless) ──
command -v "$AGENT_NAME" >/dev/null 2>&1 || die "'$AGENT_NAME' not installed / not on PATH"
# direct route also skips the RTK wrapper (raw CLI); proxy/bypass keep it
if [ "$ROUTE" = "d" ]; then declare -a CMD=("$AGENT_NAME"); else declare -a CMD=(rtk "$AGENT_NAME"); fi
_model() { if [ -n "$MODEL" ]; then CMD+=(--model "$MODEL"); fi; }

case "$AGENT_NAME" in
    claude)
        CMD+=(--dangerously-skip-permissions); _model
        case "$RUNBASE" in
            continue) CMD+=(--continue) ;;
            resume)   [ -n "$SESSION" ] && CMD+=(--resume "$SESSION") || CMD+=(--resume) ;;
        esac
        [ "$HEADLESS" = 1 ] && CMD+=(-p "$PROMPT") ;;
    qwen)
        CMD+=(--auth-type openai -y); _model
        case "$RUNBASE" in
            continue) CMD+=(--continue) ;;
            resume)   [ -n "$SESSION" ] && CMD+=(--resume "$SESSION") || CMD+=(--resume) ;;
        esac
        [ "$HEADLESS" = 1 ] && CMD+=(--prompt "$PROMPT") ;;
    codex)
        case "$RUNBASE" in
            continue) CMD+=(resume --last) ;;
            resume)   [ -n "$SESSION" ] && CMD+=(resume "$SESSION") || CMD+=(resume) ;;
            init)     CMD+=(--dangerously-bypass-approvals-and-sandbox); _model ;;
        esac
        [ "$HEADLESS" = 1 ] && CMD+=("$PROMPT") ;;
    opencode)
        _model
        case "$RUNBASE" in
            continue) CMD+=(--continue) ;;
            resume)   [ -n "$SESSION" ] && CMD+=(--session "$SESSION") || CMD+=(--continue) ;;
        esac
        [ "$HEADLESS" = 1 ] && CMD+=(--prompt "$PROMPT") ;;
    hermes)
        [ -n "$MODEL" ] && warn "hermes model is profile-driven; ignoring -m/$MODELCODE"
        CMD+=(--yolo)
        case "$RUNBASE" in
            continue) CMD+=(--continue) ;;
            resume)   CMD+=(--resume "${SESSION:-}") ;;
        esac
        [ "$HEADLESS" = 1 ] && CMD+=(chat -q "$PROMPT") ;;
    pi)
        _model
        case "$RUNBASE" in
            continue) CMD+=(--continue) ;;
            resume)   [ -n "$SESSION" ] && CMD+=(--session "$SESSION") ;;
        esac
        [ "$HEADLESS" = 1 ] && CMD+=(--prompt "$PROMPT") ;;
    *)  _model; [ "$HEADLESS" = 1 ] && CMD+=("$PROMPT") ;;
esac

# ── dry-run / verbose / exec ─────────────────────────────────────────────────
if [ "$VERBOSE" = 1 ] || [ "$DRYRUN" = 1 ]; then
    note "agent=$AGENT_NAME run=$RUNBASE headless=$HEADLESS route=$ROUTE model=${MODEL:-<default>} profile=$PROFILE"
    note "→ ${ENVV[*]:-(direct)} ${CMD[*]}"
fi
[ "$DRYRUN" = 1 ] && exit 0

if [ "$CRASH_GUARD" = 1 ] && [ "$ROUTE" != "d" ] && command -v cg_run >/dev/null 2>&1; then
    exec env "${ENVV[@]}" cg_run "$AGENT_NAME" -- "${CMD[@]}"
else
    exec env ${ENVV[@]:+"${ENVV[@]}"} "${CMD[@]}"
fi
