{
  "schema_version": "2.0.0",
  "entries": [
    {
      "id": "claude_code_proxy",
      "name": "Claude Code Proxy",
      "url": "http://127.0.0.1:8082/v1",
      "auth_key": "",
      "enabled": true,
      "order": 0,
      "service_cmd": ".venv/bin/python start_proxy.py --skip-validation",
      "service_stop_cmd": "",
      "health_path": "/health",
      "port": 8082,
      "timeout": 90,
      "extra_headers": {},
      "type": "http",
      "model_prefixes": []
    },
    {
      "id": "headroom",
      "name": "Headroom",
      "url": "http://127.0.0.1:8787/v1",
      "auth_key": "",
      "enabled": true,
      "order": 1,
      "service_cmd": "headroom proxy --port 8787",
      "service_stop_cmd": "",
      "health_path": "/health",
      "port": 8787,
      "timeout": 90,
      "extra_headers": {},
      "type": "http",
      "model_prefixes": []
    },
    {
      "id": "rtk",
      "name": "RTK",
      "url": "http://127.0.0.1:8788/v1",
      "auth_key": "",
      "enabled": false,
      "order": 2,
      "service_cmd": "rtk serve --port 8788",
      "service_stop_cmd": "",
      "health_path": "/health",
      "port": 8788,
      "timeout": 90,
      "extra_headers": {},
      "type": "http",
      "model_prefixes": []
    }
