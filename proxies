cmd_router() {
    local action="${1:-show}"
    shift 2>/dev/null || true

    case "$action" in
        show)       _router_show ;;
        set)        _router_set "$@" ;;
        clear)      _router_clear "$@" ;;
        disable)    _router_disable ;;
        enable)     _router_enable ;;
        passthrough) _router_passthrough ;;
        *)
            echo -e "\n${CYAN}Usage:${NC} proxies router {show|set|clear|disable|enable|passthrough}"
            echo ""
            echo "  show                  Show current task-based model routing"
            echo "  set <slot> <model>    Set model for a routing slot"
            echo "  clear <slot>          Clear override (fall back to tier model)"
            echo "  disable               Disable ALL task substitutions (tier models only)"
            echo "  enable                Re-enable task substitutions"
            echo "  passthrough           Anthropic Pro mode (bypass all routing)"
            echo ""
            echo -e "  ${CYAN}Slots:${NC} default, background, think, long_context, web_search, image"
            echo ""
            echo -e "  ${CYAN}Examples:${NC}"
            echo "    proxies router set background nvidia/nemotron-nano-9b-v2:free"
            echo "    proxies router set think tngtech/tng-r1t-chimera:free"
            echo "    proxies router clear web_search"
            echo "    proxies router disable"
            echo "    proxies router passthrough"
            echo ""
            ;;
    esac
}

_router_show() {
    echo -e "\n${CYAN}Task-Based Model Router${NC}\n"

    _python - "$CHAIN_FILE" <<'PYEOF'
import json, sys, os
path = sys.argv[1]
data = json.loads(open(path).read())
router = data.get("router", {})

# Check if routing is disabled
disabled = router.get("_disabled", False)
passthrough = router.get("_passthrough", False)

if passthrough:
    print("  \033[0;33m⚠ PASSTHROUGH MODE\033[0m — All requests go directly to Anthropic API")
    print("    No model substitution, no cascade, no routing.\n")
elif disabled:
    print("  \033[0;33m⚠ ROUTING DISABLED\033[0m — All slots fall through to tier models")
    print("    Use 'proxies router enable' to re-activate.\n")

slots = [
    ("default",      "General tasks"),
    ("background",   "Haiku-class / tool summaries"),
    ("think",        "Reasoning / Plan Mode"),
    ("long_context", "Large context (>threshold)"),
    ("web_search",   "Web search tool calls"),
    ("image",        "Vision / image requests"),
]

for slot, desc in slots:
    val = router.get(slot, "")
    if isinstance(val, dict):
        val = val.get("model", "")

    env_var = f"ROUTER_{slot.upper()}"
    env_val = os.environ.get(env_var, "")

    if env_val and env_val != val:
        # Env override active
        print(f"  {slot:<16} → \033[0;32m{env_val}\033[0m  \033[0;33m(env override)\033[0m")
        if val:
            print(f"  {'':16}   \033[0;90m(json: {val})\033[0m")
    elif val:
        print(f"  {slot:<16} → \033[0;32m{val}\033[0m")
    else:
        print(f"  {slot:<16}   \033[0;90m(tier fallback)\033[0m")

    print(f"  {'':16}   {desc}")
    print()

threshold = router.get("long_context_threshold", 60000)
print(f"  {'threshold':<16} → {threshold:,} tokens")
custom = router.get("custom_router_path", "")
if custom:
    print(f"  {'custom_router':<16} → {custom}")
print()
PYEOF
}

_router_set() {
    local slot="$1" model="$2"
    if [ -z "$slot" ] || [ -z "$model" ]; then
        fail "Usage: proxies router set <slot> <model>"
        return 1
    fi

    local valid_slots="default background think long_context web_search image long_context_threshold custom_router_path"
    if [[ ! " $valid_slots " =~ " $slot " ]]; then
        fail "Invalid slot '$slot'. Valid: $valid_slots"
        return 1
    fi

    _python - "$CHAIN_FILE" "$slot" "$model" <<'PYEOF'
import json, sys
path, slot, model = sys.argv[1], sys.argv[2], sys.argv[3]
data = json.loads(open(path).read())
router = data.setdefault("router", {})

if slot == "long_context_threshold":
    router[slot] = int(model)
elif slot == "custom_router_path":
    router[slot] = model
else:
    # Store as RouteTarget dict for consistency with proxy_chain.py
    router[slot] = {"model": model, "base_url": "", "api_key": ""}

with open(path, 'w') as f:
    json.dump(data, f, indent=2)
print(f"  ✓ router.{slot} = {model}")
PYEOF

    # Also update .env if it exists
    local env_file="$PROXY_DIR/.env"
    if [ -f "$env_file" ]; then
        local env_var="ROUTER_${slot^^}"
        if grep -q "^${env_var}=" "$env_file" 2>/dev/null; then
            sed -i "s|^${env_var}=.*|${env_var}=${model}|" "$env_file"
            ok "Updated $env_var in .env"
        else
            echo "${env_var}=${model}" >> "$env_file"
            ok "Added $env_var to .env"
        fi
    fi
}

_router_clear() {
    local slot="$1"
    if [ -z "$slot" ]; then
        fail "Usage: proxies router clear <slot>"
        return 1
    fi

    _python - "$CHAIN_FILE" "$slot" <<'PYEOF'
import json, sys
path, slot = sys.argv[1], sys.argv[2]
data = json.loads(open(path).read())
router = data.setdefault("router", {})
router[slot] = {"model": "", "base_url": "", "api_key": ""}

with open(path, 'w') as f:
    json.dump(data, f, indent=2)
print(f"  ✓ router.{slot} cleared (tier fallback)")
PYEOF

    # Clear from .env too
    local env_file="$PROXY_DIR/.env"
    local env_var="ROUTER_${slot^^}"
    if [ -f "$env_file" ] && grep -q "^${env_var}=" "$env_file" 2>/dev/null; then
        sed -i "s|^${env_var}=.*|${env_var}=|" "$env_file"
        ok "Cleared $env_var in .env"
    fi
}

