    "port": port,
    "timeout": 90,
    "extra_headers": {},
    "type": entry_type,
    "model_prefixes": [],
}
entries.append(new_entry)
data["entries"] = entries

with open(path, 'w') as f:
    json.dump(data, f, indent=2)
print(f"  ✓ Added '{name}' (id={entry_id}, type={entry_type})")
PYEOF
}

_config_remove() {
