        success = stats.get("success", 0)
        fail = stats.get("failure", stats.get("fail", 0))
        total = success + fail
        rate = (success / total * 100) if total > 0 else 0
        print(f"  {name[:30]:<30} {success:>4}✓ {fail:>3}✗  ({rate:.0f}% success)")
else:
    print("  (unexpected data format)")
print()
PYEOF
}

