#!/usr/bin/env bash
# ═══════════════════════════════════════════════════════════════════
# proxies — Manage the proxy chain lifecycle
#
# Usage:
#   proxies up              → Start all chain services in tmux
#   proxies down            → Kill everything
#   proxies status          → Show running services (from chain config)
#   proxies logs            → Tail all log files in real-time
#   proxies watch [svc]     → Monitor tmux pane output
#   proxies chain           → Open the chain manager TUI
#   proxies restart
#
# Chain topology is configured in config/proxy_chain.json.
# Edit with:  proxies chain
# ═══════════════════════════════════════════════════════════════════

set -euo pipefail

PROXY_DIR="/home/cheta/code/claude-code-proxy"
LOG_DIR="/tmp/proxy-logs"
TMUX_SESSION="proxies"
CHAIN_FILE="$PROXY_DIR/config/proxy_chain.json"

# ── Colors ──
GREEN='\033[0;32m'; RED='\033[0;31m'; CYAN='\033[0;36m'
YELLOW='\033[0;33m'; NC='\033[0m'

ok()   { echo -e "  ${GREEN}✓${NC} $*"; }
fail() { echo -e "  ${RED}✗${NC} $*"; }
info() { echo -e "  ${CYAN}→${NC} $*"; }
warn() { echo -e "  ${YELLOW}⚠${NC} $*"; }

mkdir -p "$LOG_DIR"

# ── Resolve python in venv or system ──
_python() {
    if [ -f "$PROXY_DIR/.venv/bin/python" ]; then
        "$PROXY_DIR/.venv/bin/python" "$@"
    else
        python3 "$@"
    fi
}

# ── Read chain entries that have a service_cmd (in reverse start order) ──
# Outputs one line per entry: id|name|service_cmd|port|health_path
# Reverse order = upstream services start before downstream consumers.
_chain_services_reversed() {
    _python - <<'PYEOF'
import json, sys, os
path = os.environ.get("CHAIN_FILE", "config/proxy_chain.json")
try:
    data = json.loads(open(path).read())
except Exception:
    sys.exit(0)
entries = data.get("entries", [])
enabled = [e for e in entries if e.get("enabled") and e.get("service_cmd","").strip()]
enabled.sort(key=lambda e: e.get("order", 0))
for e in reversed(enabled):
    print(f"{e['id']}|{e.get('name','?')}|{e.get('service_cmd','')}|{e.get('port',0)}|{e.get('health_path','/health')}")
PYEOF
}

# Same but forward order (for status display) — includes cli_wrappers (no service_cmd)
_chain_services() {
    _python - <<'PYEOF'
import json, sys, os
path = os.environ.get("CHAIN_FILE", "config/proxy_chain.json")
try:
    data = json.loads(open(path).read())
except Exception:
    sys.exit(0)
entries = data.get("entries", [])
enabled = [e for e in entries if e.get("enabled")]
enabled.sort(key=lambda e: e.get("order", 0))
for e in enabled:
    print(f"{e['id']}|{e.get('name','?')}|{e.get('service_cmd','')}|{e.get('port',0)}|{e.get('health_path','/health')}|{e.get('type','http')}")
PYEOF
}

# ── Health check helpers ──
wait_for_port() {
    local port=$1 timeout=${2:-30} endpoint=${3:-/health}
    for i in $(seq 1 $timeout); do
        curl -sf --max-time 1 "http://127.0.0.1:$port$endpoint" > /dev/null 2>&1 && return 0
        sleep 1
    done
    return 1
}

# ── Kill all managed processes ──
cmd_stop() {
    echo -e "\n${CYAN}Stopping proxies${NC}"
    # Kill processes matching service_cmds in chain, plus legacy patterns
    while IFS='|' read -r id name cmd port health type; do
        [ -z "$cmd" ] && continue  # skip cli_wrappers with no service_cmd
        local pattern
        pattern=$(echo "$cmd" | awk '{print $1}' | xargs basename 2>/dev/null || echo "$id")
        pkill -f "$pattern" 2>/dev/null && echo "  Stopped: $name" || true
    done < <(CHAIN_FILE="$CHAIN_FILE" _chain_services)
    # Legacy cleanup
    pkill -f "start_proxy.py" 2>/dev/null || true
    pkill -f "headroom proxy" 2>/dev/null || true
    pkill -f "cli-proxy-api-plus" 2>/dev/null || true
    tmux kill-session -t "$TMUX_SESSION" 2>/dev/null || true
    echo ""
}

# ── Launch chain services inside a tmux session ──
_launch_chain_tmux() {
    # Read entries to start (reversed = upstream first)
    mapfile -t entries < <(CHAIN_FILE="$CHAIN_FILE" _chain_services_reversed)

    if [ ${#entries[@]} -eq 0 ]; then
        warn "No enabled chain services with service_cmd found in $CHAIN_FILE"
        info "Add services via: proxies chain"
        return 1
    fi

    # Note: Claude Code Proxy is now a first-class entry in proxy_chain.json
    # (order=0, so reversed-start puts it last — upstream services ready first).

    # Create tmux session with first entry
    local first_entry="${entries[0]}"
    IFS='|' read -r id name cmd port health <<< "$first_entry"
    tmux new-session -d -s "$TMUX_SESSION" -n "proxies"
    tmux send-keys -t "${TMUX_SESSION}:0.0" \
        "echo -e \"\\033[1;33m── $name (:$port) ──\\033[0m\"" C-m
    tmux send-keys -t "${TMUX_SESSION}:0.0" "$cmd" C-m

    local pane=1
    # Remaining chain entries
    for entry in "${entries[@]:1}"; do
        IFS='|' read -r id name cmd port health <<< "$entry"
        tmux split-window -v -t "${TMUX_SESSION}:0.$((pane-1))"
        tmux send-keys -t "${TMUX_SESSION}:0.${pane}" \
            "echo -e \"\\033[1;33m── $name (:$port) ──\\033[0m\"" C-m
        tmux send-keys -t "${TMUX_SESSION}:0.${pane}" "$cmd" C-m
        pane=$((pane+1))
    done

    # (Claude Code Proxy is launched via the entry loop above, as order=0 in
    # proxy_chain.json — reversed-start puts it in the final pane.)

    tmux select-layout -t "$TMUX_SESSION" even-vertical
    tmux rename-window -t "$TMUX_SESSION" "chain"

    # ── Pane status bars ──
    # Show a per-pane status line at the bottom of each pane, refreshed every 5s.
    # Uses pane-border-status for a compact per-pane label at the top border.
    local status_script="$PROXY_DIR/scripts/tmux_status.sh"
    if [ -x "$status_script" ]; then
        tmux set-option -t "$TMUX_SESSION" -g pane-border-status top
        tmux set-option -t "$TMUX_SESSION" -g pane-border-format "#{pane_title}"
        tmux set-option -t "$TMUX_SESSION" -g status-interval 5
        tmux set-option -t "$TMUX_SESSION" -g status-left-length 200
        tmux set-option -t "$TMUX_SESSION" -g status-right-length 200
        # Bottom status bar: proxy summary + headroom summary + rtk summary
        tmux set-option -t "$TMUX_SESSION" -g status-left "#(${status_script} proxy) "
        tmux set-option -t "$TMUX_SESSION" -g status-right "#(${status_script} headroom) │ #(${status_script} rtk)"
        tmux set-option -t "$TMUX_SESSION" -g status-bg "colour235"
        tmux set-option -t "$TMUX_SESSION" -g status-fg "white"
    fi
}

# ── Main start command ──
cmd_start() {
    echo -e "\n${CYAN}Starting proxy chain${NC}\n"

    if tmux has-session -t "$TMUX_SESSION" 2>/dev/null; then
        info "Existing tmux session found — killing..."
        tmux kill-session -t "$TMUX_SESSION" 2>/dev/null || true
        sleep 1
    fi

    # Kill stale processes
    cmd_stop 2>/dev/null || true
    sleep 1

    info "Launching chain in tmux..."
    _launch_chain_tmux

    info "Waiting for services to start..."
    sleep 3

    local all_ok=true

    # Health-check each chain entry (skip CLI wrappers)
    while IFS='|' read -r id name cmd port health type; do
        if [ "$port" -gt 0 ]; then
            wait_for_port "$port" 30 "$health" && ok "$name :$port" || { fail "$name :$port"; all_ok=false; }
        fi
    done < <(CHAIN_FILE="$CHAIN_FILE" _chain_services)

    # Health-check the proxy itself
    wait_for_port 8082 30 /health && ok "Claude Code Proxy :8082" || { fail "Claude Code Proxy :8082"; all_ok=false; }

    echo ""
    if [ "$all_ok" = true ]; then
        echo -e "  ${CYAN}View live output:${NC} tmux attach -t $TMUX_SESSION"
        echo -e "  ${CYAN}Detach:${NC}          Ctrl+B, then D"
        echo ""
        if [ -t 1 ]; then
            info "Attaching to tmux session..."
            tmux attach -t "$TMUX_SESSION"
        fi
    else
        echo -e "  ${RED}Some services failed to start.${NC}"
        echo -e "  ${CYAN}Check tmux panes:${NC} tmux attach -t $TMUX_SESSION"
        echo ""
        return 1
    fi
}

# ── Status: show chain entries + health ──
cmd_status() {
    echo -e "\n${CYAN}Proxy chain status${NC}"

    if tmux has-session -t "$TMUX_SESSION" 2>/dev/null; then
        local attached
        attached=$(tmux list-clients -t "$TMUX_SESSION" 2>/dev/null | wc -l)
        if [ "$attached" -gt 0 ]; then
            echo -e "  ${GREEN}✓${NC} tmux session: $TMUX_SESSION ($attached client(s) attached)"
        else
            echo -e "  ${GREEN}✓${NC} tmux session: $TMUX_SESSION (detached)"
        fi
        echo -e "      Attach: ${CYAN}tmux attach -t $TMUX_SESSION${NC}"
        echo ""
    fi

    echo -e "  Chain entries (from $CHAIN_FILE):"
    local idx=1
    while IFS='|' read -r id name cmd port health type; do
        if [ "$type" = "cli_wrapper" ] || [ "$port" -eq 0 ]; then
            echo -e "  ${YELLOW}[$idx]${NC} $name  ${YELLOW}(CLI wrapper — passive, no port)${NC}"
        elif [ "$port" -gt 0 ]; then
            if curl -sf --max-time 2 "http://127.0.0.1:$port$health" > /dev/null 2>&1; then
                echo -e "  ${GREEN}[$idx]${NC} $name  :$port  ${GREEN}(healthy)${NC}"
            else
                echo -e "  ${RED}[$idx]${NC} $name  :$port  ${RED}(unreachable)${NC}"
            fi
        fi
        idx=$((idx+1))
    done < <(CHAIN_FILE="$CHAIN_FILE" _chain_services)

    # Always show the proxy itself
    if curl -sf --max-time 2 "http://127.0.0.1:8082/health" > /dev/null 2>&1; then
        echo -e "  ${GREEN}[$idx]${NC} Claude Code Proxy  :8082  ${GREEN}(healthy)${NC}"
    else
        echo -e "  ${RED}[$idx]${NC} Claude Code Proxy  :8082  ${RED}(not running)${NC}"
    fi
    echo ""
}

# ── Chain TUI ──
cmd_chain() {
    cd "$PROXY_DIR"
    source .venv/bin/activate 2>/dev/null || true
    python -m src.cli.chain_tui
}

# ── Statusline builder TUI ──
cmd_statusline() {
    cd "$PROXY_DIR"
    source .venv/bin/activate 2>/dev/null || true
    # Ensure textual is installed (silent no-op if already present)
    python -c "import textual" 2>/dev/null || pip install -q "textual>=0.47.0"
    python -m src.cli.statusline_tui
}

# ── Log tailing ──
cmd_logs() {
    echo -e "\n${CYAN}Tailing proxy logs (Ctrl+C to stop)${NC}\n"

    if tmux has-session -t "$TMUX_SESSION" 2>/dev/null; then
        warn "tmux session '$TMUX_SESSION' is running — run 'tmux attach -t $TMUX_SESSION' for live output"
        echo ""
        return 1
    fi

    local found=0
    for f in "$LOG_DIR"/*.log; do
        [ -f "$f" ] && found=1 && break
    done
    if [ "$found" -eq 0 ]; then
        fail "No log files found in $LOG_DIR"
        info "Start proxies first: proxies up"
        return 1
    fi

    tail -f "$LOG_DIR"/*.log 2>/dev/null
}

# ── Watch tmux pane output ──
cmd_watch() {
    local service="${1:-all}"
    local lines="${2:-20}"

    if ! tmux has-session -t "$TMUX_SESSION" 2>/dev/null; then
        fail "No tmux session '$TMUX_SESSION' — start proxies first"
        info "Run: proxies up"
        return 1
    fi

    # Delegate to rich dashboard script if available
    if [ "$service" = "all" ] && [ -f "$PROXY_DIR/scripts/watch_dashboard.py" ]; then
        source .venv/bin/activate 2>/dev/null || true
        exec python3 "$PROXY_DIR/scripts/watch_dashboard.py" "$TMUX_SESSION" "chain" "$lines"
    fi

    # Simple pane capture
    local total_panes
    total_panes=$(tmux list-panes -t "$TMUX_SESSION" 2>/dev/null | wc -l)
    local colors=("$GREEN" "$YELLOW" "$CYAN" "$GREEN" "$YELLOW" "$CYAN")

    echo -e "\n${CYAN}Monitoring proxy panes (Ctrl+C to stop)${NC}\n"
    local running=true
    trap 'running=false' INT TERM

    declare -A prev_hash

    while $running; do
        for p in $(seq 0 $((total_panes-1))); do
            local color="${colors[$((p % ${#colors[@]}))]}"
            local content
            content=$(tmux capture-pane -t "${TMUX_SESSION}:0.${p}" -p -S "-$((lines+5))" 2>/dev/null | head -n "$lines" | sed 's/\x1b\[[0-9;]*[a-zA-Z]//g')
            local cur_hash
            cur_hash=$(printf "%s" "$content" | md5sum | cut -d' ' -f1)

            if [ "${prev_hash[$p]:-}" != "$cur_hash" ]; then
                echo -e "  ${color}── pane $p ────────────────────────────────────${NC}"
                printf "%s\n" "$content" | while IFS= read -r line; do
                    [ -z "$line" ] && continue
                    echo -e "  ${color}${line}${NC}"
                done
                echo ""
                prev_hash[$p]="$cur_hash"
            fi
        done
        for _i in $(seq 1 15); do $running || break; sleep 0.1; done
    done

    echo -e "\n${CYAN}Watch stopped.${NC}"
}

# ── Stats: compression metrics + usage summary ──
cmd_stats() {
    echo -e "\n${CYAN}Proxy Statistics${NC}\n"

    # Check proxy is running
    if ! curl -sf --max-time 2 "http://127.0.0.1:8082/health" > /dev/null 2>&1; then
        fail "Claude Code Proxy is not running on :8082"
        return 1
    fi

    # Fetch stats from API
    local stats
    stats=$(curl -sf --max-time 5 "http://127.0.0.1:8082/api/stats" 2>/dev/null)
    if [ -z "$stats" ]; then
        fail "Could not fetch stats from proxy API"
        return 1
    fi

    # Parse and display
    local requests tokens cost latency
    requests=$(echo "$stats" | _python -c "import json,sys; d=json.load(sys.stdin); print(d.get('requests_today',0))" 2>/dev/null)
    tokens=$(echo "$stats" | _python -c "import json,sys; d=json.load(sys.stdin); t=d.get('total_tokens',0); print(f'{t:,}' if t else '0')" 2>/dev/null)
    cost=$(echo "$stats" | _python -c "import json,sys; d=json.load(sys.stdin); print(f\"\${d.get('est_cost',0):.4f}\")" 2>/dev/null)
    latency=$(echo "$stats" | _python -c "import json,sys; d=json.load(sys.stdin); print(f\"{d.get('avg_latency',0)}ms\")" 2>/dev/null)

    echo -e "  ${GREEN}Requests today:${NC}  $requests"
    echo -e "  ${GREEN}Total tokens:${NC}    $tokens"
    echo -e "  ${GREEN}Est. cost:${NC}       $cost"
    echo -e "  ${GREEN}Avg latency:${NC}     $latency"

    # RTK compression stats (if rtk is installed)
    echo ""
    if command -v rtk &>/dev/null; then
        echo -e "  ${CYAN}RTK Token Savings:${NC}"
        rtk gain 2>/dev/null | while IFS= read -r line; do
            echo "    $line"
        done
    else
        echo -e "  ${YELLOW}RTK not installed — no terminal compression stats${NC}"
    fi

    # Recent requests
    echo ""
    echo -e "  ${CYAN}Recent requests:${NC}"
    echo "$stats" | _python -c "
import json, sys
d = json.load(sys.stdin)
for r in d.get('recent_requests', [])[:5]:
    model = r.get('model','?')[:35]
    tokens = r.get('tokens', 0)
    dur = r.get('duration', 0)
    status = r.get('status', '?')
    icon = '✓' if status == 'success' else '✗'
    print(f'    {icon} {model:<35} {tokens:>7} tok  {dur:>5}ms')
" 2>/dev/null

    # Cascade stats
    echo ""
    echo -e "  ${CYAN}Cascade events:${NC}"
    echo "$stats" | _python -c "
import json, sys
d = json.load(sys.stdin)
cascade = d.get('cascade', {})
events = cascade.get('events', [])
if not events:
    print('    (none)')
else:
    for e in events[:5]:
        model = e.get('model','?')[:30]
        action = e.get('action','?')
        reason = e.get('reason','')[:25]
        print(f'    {action:<10} {model:<30} {reason}')
" 2>/dev/null

    echo ""
}

# ══════════════════════════════════════════════════════════════════════════════
# CONFIG — View/edit all proxy settings interactively
# ══════════════════════════════════════════════════════════════════════════════

cmd_config() {
    local action="${1:-show}"
    shift 2>/dev/null || true

    case "$action" in
        show)   _config_show ;;
        set)    _config_set "$@" ;;
        toggle) _config_toggle "$@" ;;
        order)  _config_reorder "$@" ;;
        add)    _config_add "$@" ;;
        rm)     _config_remove "$@" ;;
        env)    _config_env ;;
        *)
            echo -e "\n${CYAN}Usage:${NC} proxies config {show|set|toggle|order|add|rm|env}"
            echo ""
            echo "  show                    Show all chain entries and settings"
            echo "  set <id> <key> <value>  Set a property on a chain entry"
            echo "  toggle <id>             Toggle a chain entry enabled/disabled"
            echo "  order <id> up|down      Move a chain entry up or down"
            echo "  add <id> <name> <url>   Add a new chain entry"
            echo "  rm <id>                 Remove a chain entry"
            echo "  env                     Show all relevant env vars"
            echo ""
            echo -e "  ${CYAN}Examples:${NC}"
            echo "    proxies config show"
            echo "    proxies config toggle cliproxyapi"
            echo "    proxies config set headroom port 8787"
            echo "    proxies config set headroom service_cmd 'headroom proxy --port 8787 --mode cost_savings'"
            echo "    proxies config order headroom down"
            echo "    proxies config add myproxy 'My Proxy' http://127.0.0.1:9000/v1"
            echo ""
            ;;
    esac
}

_config_show() {
    echo -e "\n${CYAN}Proxy Chain Configuration${NC}"
    echo -e "  ${YELLOW}File:${NC} $CHAIN_FILE\n"

    _python - "$CHAIN_FILE" <<'PYEOF'
import json, sys
path = sys.argv[1]
try:
    data = json.loads(open(path).read())
except Exception as e:
    print(f"  Error reading {path}: {e}")
    sys.exit(1)

entries = data.get("entries", [])
for i, e in enumerate(entries):
    enabled = "✓" if e.get("enabled") else "✗"
    color = "\033[0;32m" if e.get("enabled") else "\033[0;31m"
    nc = "\033[0m"
    etype = e.get("type", "http")
    port_str = f":{e['port']}" if e.get("port", 0) > 0 else ""
    url = e.get("url", "") or "(no URL)"
    if etype == "cli_wrapper":
        url = "(CLI wrapper)"

    print(f"  {color}[{enabled}]{nc} {i+1}. {e.get('name','?')}  {url}{port_str}")
    print(f"       id={e['id']}  type={etype}  order={e.get('order',0)}  timeout={e.get('timeout',90)}s")
    if e.get("service_cmd"):
        cmd = e["service_cmd"]
        if len(cmd) > 70:
            cmd = cmd[:67] + "..."
        print(f"       cmd: {cmd}")
    if e.get("health_path") and e.get("health_path") != "/health":
        print(f"       health: {e['health_path']}")
    print()

# Router section
router = data.get("router", {})
if router:
    print(f"  \033[0;36mModel Router:\033[0m")
    slots = ["default", "background", "think", "long_context", "web_search", "image"]
    for slot in slots:
        val = router.get(slot, "")
        if isinstance(val, dict):
            val = val.get("model", "")
        label = f"    {slot:<20}"
        if val:
            print(f"{label} → {val}")
        else:
            print(f"{label}   (tier fallback)")
    threshold = router.get("long_context_threshold", 60000)
    print(f"    {'threshold':<20} → {threshold:,} tokens")
    custom = router.get("custom_router_path", "")
    if custom:
        print(f"    {'custom_router':<20} → {custom}")
    print()
PYEOF
}

_config_set() {
    local entry_id="$1" key="$2" value="$3"
    if [ -z "$entry_id" ] || [ -z "$key" ] || [ -z "$value" ]; then
        fail "Usage: proxies config set <entry_id> <key> <value>"
        return 1
    fi

    _python - "$CHAIN_FILE" "$entry_id" "$key" "$value" <<'PYEOF'
import json, sys
path, entry_id, key, value = sys.argv[1], sys.argv[2], sys.argv[3], sys.argv[4]
data = json.loads(open(path).read())

found = False
for e in data.get("entries", []):
    if e["id"] == entry_id:
        found = True
        # Type coercion for known fields
        if key in ("port", "order", "timeout"):
            value = int(value)
        elif key in ("enabled",):
            value = value.lower() in ("true", "1", "yes")
        e[key] = value
        break

if not found:
    print(f"  ✗ Entry '{entry_id}' not found")
    sys.exit(1)

with open(path, 'w') as f:
    json.dump(data, f, indent=2)
print(f"  ✓ {entry_id}.{key} = {value}")
PYEOF
}

_config_toggle() {
    local entry_id="$1"
    if [ -z "$entry_id" ]; then
        fail "Usage: proxies config toggle <entry_id>"
        return 1
    fi

    _python - "$CHAIN_FILE" "$entry_id" <<'PYEOF'
import json, sys
path, entry_id = sys.argv[1], sys.argv[2]
data = json.loads(open(path).read())

for e in data.get("entries", []):
    if e["id"] == entry_id:
        e["enabled"] = not e.get("enabled", True)
        state = "enabled" if e["enabled"] else "disabled"
        with open(path, 'w') as f:
            json.dump(data, f, indent=2)
        color = "\033[0;32m" if e["enabled"] else "\033[0;31m"
        print(f"  {color}✓\033[0m {e.get('name', entry_id)}: {state}")
        sys.exit(0)

print(f"  ✗ Entry '{entry_id}' not found")
sys.exit(1)
PYEOF
}

_config_reorder() {
    local entry_id="$1" direction="$2"
    if [ -z "$entry_id" ] || [ -z "$direction" ]; then
        fail "Usage: proxies config order <entry_id> up|down"
        return 1
    fi

    _python - "$CHAIN_FILE" "$entry_id" "$direction" <<'PYEOF'
import json, sys
path, entry_id, direction = sys.argv[1], sys.argv[2], sys.argv[3]
data = json.loads(open(path).read())
entries = data.get("entries", [])

idx = next((i for i, e in enumerate(entries) if e["id"] == entry_id), -1)
if idx < 0:
    print(f"  ✗ Entry '{entry_id}' not found")
    sys.exit(1)

if direction == "up" and idx > 0:
    entries[idx-1], entries[idx] = entries[idx], entries[idx-1]
elif direction == "down" and idx < len(entries) - 1:
    entries[idx], entries[idx+1] = entries[idx+1], entries[idx]
else:
    print(f"  ⚠ Cannot move {entry_id} {direction} (already at boundary)")
    sys.exit(0)

for i, e in enumerate(entries):
    e["order"] = i
data["entries"] = entries

with open(path, 'w') as f:
    json.dump(data, f, indent=2)

for i, e in enumerate(entries):
