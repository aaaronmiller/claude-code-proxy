# ── Main dispatch ──
case "${1:-status}" in
    up|start)       cmd_start ;;
    down|stop)      cmd_stop ;;
    status|st)      cmd_status ;;
    stats)          cmd_stats ;;
    config|cfg)     shift; cmd_config "$@" ;;
    router|route)   shift; cmd_router "$@" ;;
    metrics|met)    shift; cmd_metrics "$@" ;;
    logs|log|tail)  cmd_logs ;;
    watch|mon)      cmd_watch "${2:-all}" "${3:-20}" ;;
    chain|tui)      cmd_chain ;;
    statusline|sl)  cmd_statusline ;;
    restart)        cmd_stop; sleep 2; cmd_start ;;
    help|--help|-h) cmd_help ;;
    *)
        fail "Unknown command: $1"
        echo ""
        cmd_help
        exit 1
        ;;
esac
