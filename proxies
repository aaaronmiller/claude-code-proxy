_metrics_summary() {
    echo -e "\n${CYAN}Metrics Summary${NC}\n"

    if ! curl -sf --max-time 2 "http://127.0.0.1:8082/health" > /dev/null 2>&1; then
        fail "Proxy not running on :8082"
        return 1
    fi

    local stats agg
    stats=$(curl -sf --max-time 5 "http://127.0.0.1:8082/api/stats" 2>/dev/null)
    agg=$(curl -sf --max-time 5 "http://127.0.0.1:8082/api/metrics/aggregate" 2>/dev/null)

    _python - <<PYEOF
import json, sys

stats = json.loads('''$stats''') if '''$stats''' else {}
agg_raw = json.loads('''$agg''') if '''$agg''' else {}
agg = agg_raw.get("metrics", agg_raw)

# Basic stats
requests = stats.get("requests_today", 0)
tokens = stats.get("total_tokens", 0)
cost = stats.get("est_cost", 0)
latency = stats.get("avg_latency", 0)

print(f"  Requests today:    {requests}")
print(f"  Total tokens:      {tokens:,}")
print(f"  Est. cost:         \${cost:.4f}")
print(f"  Avg latency:       {latency}ms")
print()

# Aggregate metrics
if agg:
    total_req = agg.get("total_requests", 0)
    total_tok = agg.get("total_tokens", 0)
    sessions = agg.get("active_sessions", agg.get("sessions", 0))
    print(f"  Total requests:    {total_req}")
    print(f"  Lifetime tokens:   {total_tok:,}")
    if sessions:
        print(f"  Active sessions:   {sessions}")

# Cascade
cascade = stats.get("cascade", {})
events = cascade.get("events", [])
if events:
    print()
    print("  Cascade events (recent):")
    for e in events[:5]:
        model = e.get("model","?")[:30]
        action = e.get("action","?")
        print(f"    {action:<10} {model}")
print()
PYEOF

    # RTK stats
    if command -v rtk &>/dev/null; then
        echo -e "  ${CYAN}RTK Token Savings:${NC}"
        rtk gain 2>/dev/null | while IFS= read -r line; do
            echo "    $line"
        done
        echo ""
    fi
}

_metrics_models() {
    echo -e "\n${CYAN}Per-Model Token Usage${NC}\n"

    if ! curl -sf --max-time 2 "http://127.0.0.1:8082/health" > /dev/null 2>&1; then
        fail "Proxy not running on :8082"
        return 1
    fi

    # Query the usage tracker directly via the stats/requests endpoint
    local recent
    recent=$(curl -sf --max-time 5 "http://127.0.0.1:8082/api/stats/requests" 2>/dev/null)

    _python - <<PYEOF
import json, sys
from collections import defaultdict

data = json.loads('''$recent''') if '''$recent''' else []

# Aggregate by model
models = defaultdict(lambda: {"requests": 0, "tokens": 0, "success": 0, "fail": 0})
for r in data:
    model = r.get("model", "unknown")
    models[model]["requests"] += 1
    models[model]["tokens"] += r.get("tokens", 0)
    if r.get("status") == "success":
        models[model]["success"] += 1
    else:
        models[model]["fail"] += 1

if not models:
    print("  (no request data)")
    sys.exit(0)

# Sort by token count descending
sorted_models = sorted(models.items(), key=lambda x: x[1]["tokens"], reverse=True)

print(f"  {'Model':<40} {'Reqs':>5} {'Tokens':>10} {'OK':>4} {'Fail':>4}")
print(f"  {'─'*40} {'─'*5} {'─'*10} {'─'*4} {'─'*4}")
for model, stats in sorted_models:
    name = model[:40]
    print(f"  {name:<40} {stats['requests']:>5} {stats['tokens']:>10,} {stats['success']:>4} {stats['fail']:>4}")
print()
PYEOF
}

_metrics_tools() {
    echo -e "\n${CYAN}Tool Call Analytics${NC}\n"

    if ! curl -sf --max-time 2 "http://127.0.0.1:8082/health" > /dev/null 2>&1; then
        fail "Proxy not running on :8082"
        return 1
    fi

    local tools
    tools=$(curl -sf --max-time 5 "http://127.0.0.1:8082/api/metrics/tool-analytics?hours=24" 2>/dev/null)

    _python - <<PYEOF
import json, sys

data = json.loads('''$tools''') if '''$tools''' else {}

if data.get("status") == "no_data":
    print("  (no tool analytics data yet)")
