# Claude Code Proxy Configuration
# Fixed: Uses provider/model format with correct assignments

# ═══════════════════════════════════════════════════════════════
# CORE CONFIGURATION
# ═══════════════════════════════════════════════════════════════

# Upstream: proxy chain (headroom compression at :8787)
PROVIDER_API_KEY="${OPENROUTER_API_KEY}"
PROVIDER_BASE_URL="http://127.0.0.1:8787/v1"

# ═══════════════════════════════════════════════════════════════
# MODEL CONFIGURATION (provider/model format — dynamically routed)
# ═══════════════════════════════════════════════════════════════

# BIG: Primary agentic model — OpenRouter with full tool support
BIG_MODEL="openrouter/owl-alpha"
BIG_PROVIDER="openrouter"
BIG_ENDPOINT="https://openrouter.ai/api/v1"

# MIDDLE: Fast all-rounder — OpenCode Go (expects bare model names)
MIDDLE_MODEL="opencode_go/qwen3.6-plus"
MIDDLE_PROVIDER="opencode_go"
MIDDLE_ENDPOINT="https://opencode.ai/zen/go/v1"

# SMALL: Lightweight/free fallback chain — OpenRouter free models
SMALL_MODEL="tencent/hy3-preview:free"
SMALL_PROVIDER="openrouter"
SMALL_ENDPOINT="https://openrouter.ai/api/v1"

# Small tier cascade (comma-separated model IDs)
SMALL_CASCADE="minimax/minimax-m2.5:free,openai/gpt-oss-120b:free"

# ═══════════════════════════════════════════════════════════════
# PROVIDER CONFIG (needed for cross-provider routing)
# ═══════════════════════════════════════════════════════════════

PROVIDERS_openrouter_URL="https://openrouter.ai/api/v1"
PROVIDERS_openrouter_API_KEY="${OPENROUTER_API_KEY}"

PROVIDERS_opencode_go_URL="https://opencode.ai/zen/go/v1"
PROVIDERS_opencode_go_API_KEY="${OPENCODE_GO_API_KEY}"

# ═══════════════════════════════════════════════════════════════
# REASONING CONFIGURATION
# ═══════════════════════════════════════════════════════════════

REASONING_EFFORT="low"
REASONING_MAX_TOKENS="32000"

# ═══════════════════════════════════════════════════════════════
# USAGE TRACKING
# ═══════════════════════════════════════════════════════════════

TRACK_USAGE="true"
USAGE_DB_PATH="usage_tracking.db"

# ═══════════════════════════════════════════════════════════════
# SERVER SETTINGS
# ═══════════════════════════════════════════════════════════════

HOST="0.0.0.0"
PORT="8082"
LOG_LEVEL="INFO"