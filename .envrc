source .venv/bin/activate
export PROVIDER_API_KEY="$OPENROUTER_API_KEY"
export PROVIDER_BASE_URL="https://openrouter.ai/api/v1"

# BIG_MODEL: MiniMax M2.5 (best free model available)
export BIG_MODEL="minimax/minimax-m2.5:free"

# Optional: Enable per-model routing for hybrid deployments
# export ENABLE_BIG_ENDPOINT="true"
# export BIG_ENDPOINT="https://openrouter.ai/api/v1"
# export BIG_API_KEY="$OPENROUTER_API_KEY"

# Unset ANTHROPIC_API_KEY so proxy skips client auth validation
# (Claude Code sends OAuth tokens, not env var values)
unset ANTHROPIC_API_KEY

# Compression stack integration
export OPENAI_BASE_URL="http://127.0.0.1:8787/v1"
export PROVIDER_BASE_URL="http://127.0.0.1:8787/v1"
export HEADROOM_PORT="8787"
