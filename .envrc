source .venv/bin/activate
export PROVIDER_API_KEY="$OPENROUTER_API_KEY"

# ─────────────────────────────────────────────────────────────────────────────
# PROVIDER BASE — upstream target for Claude Code Proxy
# ─────────────────────────────────────────────────────────────────────────────
# Full chain: Headroom(:8787) → ClaudeProxy(:8082) → CLIProxyAPI(:8317)
# PROVIDER_BASE_URL points to Headroom for context compression
# Headroom's OPENAI_TARGET_API_URL → :8082 (Claude Proxy)
# Claude Proxy's config → :8317 (CLIProxyAPI → Antigravity)
export PROVIDER_BASE_URL="http://127.0.0.1:8787/v1"

# ─────────────────────────────────────────────────────────────────────────────
# MODEL CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────
# When CLIProxyAPI is ENABLED (proxies up --cliproxy), override these to:
#   BIG_MODEL="gemini-3.1-pro-high"  MIDDLE_MODEL="gemini-3-flash"  SMALL_MODEL="gemini-3.1-flash-lite"
# Default: OpenRouter free models (CLIProxyAPI disabled)
BIG_MODEL="minimax/minimax-m2.5:free"
MIDDLE_MODEL="nvidia/nemotron-3-super-120b-a12b:free"
SMALL_MODEL="nvidia/nemotron-nano-9b-v2:free"

# ─────────────────────────────────────────────────────────────────────────────
# COMPRESSION STACK (Headroom + RTK)
# ─────────────────────────────────────────────────────────────────────────────
# Headroom (port 8787) = context compression proxy
# RTK = CLI wrapper that compresses terminal command output (not a proxy!)
export HEADROOM_PORT="8787"

# Unset ANTHROPIC_API_KEY so proxy skips client auth validation
# (Claude Code sends OAuth tokens, not env var values)
unset ANTHROPIC_API_KEY

# ─────────────────────────────────────────────────────────────────────────────
# FALLBACK / CASCADE
# ─────────────────────────────────────────────────────────────────────────────
# FALLBACK_METHOD controls how 429/503 errors are handled:
#   cascade           — proxy retry loop with exponential backoff + model switching
#   openrouter_native — inject "models" array into request so OpenRouter selects a healthy endpoint
#   cascade,openrouter_native — both (OR picks endpoint first; cascade wraps the whole call)
export FALLBACK_METHOD="cascade,openrouter_native"

# Enable proxy-level cascade (required for FALLBACK_METHOD=cascade to take effect)
export MODEL_CASCADE="true"

# Cascade fallback models for each tier (comma-separated, tried in order after primary fails)
export BIG_CASCADE="qwen/qwen3-235b-a22b:free,openai/gpt-oss-120b:free,minimax/minimax-m2.5:free"
export MIDDLE_CASCADE="qwen/qwen3-235b-a22b:free,openai/gpt-oss-120b:free,nvidia/nemotron-nano-9b-v2:free"
export SMALL_CASCADE="nvidia/nemotron-nano-9b-v2:free,minimax/minimax-m2.5:free,qwen/qwen3-30b-a3b:free"

# OpenRouter native fallback model list (used when openrouter_native is active)
# OpenRouter caps the total `models` array at 3 entries, and the proxy prepends
# the primary model, so keep this list at 2 fallbacks max.
export OPENROUTER_FALLBACK_MODELS="qwen/qwen3-235b-a22b:free,minimax/minimax-m2.5:free"

# ─────────────────────────────────────────────────────────────────────────────
# MODEL ROUTER  (per use-case routing — mirrors Claude Code Router semantics)
# ─────────────────────────────────────────────────────────────────────────────
# Leave blank to fall through to tier model. Overrides proxy_chain.json router section.
export ROUTER_DEFAULT=""
export ROUTER_BACKGROUND="nvidia/nemotron-nano-9b-v2:free"
export ROUTER_THINK=""
export ROUTER_LONG_CONTEXT="minimax/minimax-m2.5:free"
export ROUTER_LONG_CONTEXT_THRESHOLD="60000"
export ROUTER_WEB_SEARCH=""
export ROUTER_IMAGE="qwen/qwen2.5-vl-72b-instruct"
export ROUTER_CUSTOM_PATH=""

# ─────────────────────────────────────────────────────────────────────────────
# FEATURES
# ─────────────────────────────────────────────────────────────────────────────
# ENABLE_DASHBOARD=true
TRACK_USAGE=true
LOG_LEVEL=info
