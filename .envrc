source .venv/bin/activate
export PROVIDER_API_KEY="$OPENROUTER_API_KEY"

# ─────────────────────────────────────────────────────────────────────────────
# PROVIDER BASE — upstream target for Claude Code Proxy
# ─────────────────────────────────────────────────────────────────────────────
# Full chain: Headroom(:8787) → ClaudeProxy(:8082) → CLIProxyAPI(:8317)
# PROVIDER_BASE_URL points to Headroom for context compression
# Headroom's OPENAI_TARGET_API_URL → :8082 (Claude Proxy)
# Claude Proxy's config → :8317 (CLIProxyAPI → Antigravity)
export PROVIDER_BASE_URL="http://127.0.0.1:8787/v1"

# ─────────────────────────────────────────────────────────────────────────────
# MODEL CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────
# Models are resolved via CLIProxyAPI's oauth-model-alias routing
BIG_MODEL="minimax/minimax-m2.7"
MIDDLE_MODEL="stepfun/step-3.5-flash:free"
SMALL_MODEL="openai/gpt-oss-120b:free"

# ─────────────────────────────────────────────────────────────────────────────
# COMPRESSION STACK (Headroom + RTK)
# ─────────────────────────────────────────────────────────────────────────────
# Headroom (port 8787) = context compression proxy
# RTK = CLI wrapper that compresses terminal command output (not a proxy!)
export HEADROOM_PORT="8787"

# Unset ANTHROPIC_API_KEY so proxy skips client auth validation
# (Claude Code sends OAuth tokens, not env var values)
unset ANTHROPIC_API_KEY

# ─────────────────────────────────────────────────────────────────────────────
# FEATURES
# ─────────────────────────────────────────────────────────────────────────────
# ENABLE_DASHBOARD=true
TRACK_USAGE=true
LOG_LEVEL=debug
